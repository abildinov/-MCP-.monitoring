# DeepSeek V3.1 API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Telegram Bot Configuration  
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# DeepSeek Model Settings
DEEPSEEK_MAX_TOKENS=1000
DEEPSEEK_TEMPERATURE=0.7

# Prometheus Configuration
PROMETHEUS_URL=http://147.45.157.2:9090
PROMETHEUS_TIMEOUT=10

# Loki Configuration
LOKI_URL=http://147.45.157.2:3100
LOKI_TIMEOUT=10

# Grafana Configuration
GRAFANA_URL=http://147.45.157.2:3000
GRAFANA_API_TOKEN=your_grafana_api_token_here

# MCP Server Configuration
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000
MCP_SERVER_TIMEOUT=30

# Alert Thresholds
CPU_THRESHOLD=80
MEMORY_THRESHOLD=85
DISK_THRESHOLD=90

# HTTP Client Settings
HTTP_TIMEOUT=10
HTTP_RETRIES=3

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# TimeWeb Cloud AI Settings
TIMEWEB_API_URL=https://api.timeweb.cloud/ai/v1
TIMEWEB_MODEL=deepseek-chat